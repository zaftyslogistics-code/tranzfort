**/android/.gradle/
**/android/app/debug/
**/android/app/profile/
**/android/app/release/
**/android/key.properties
**/android/local.properties
**/android/gradle/wrapper/gradle-wrapper.jar
**/android/captures/
**/android/gradlew
**/android/gradlew.bat
**/android/**/*.keystore
**/android/**/*.jks

