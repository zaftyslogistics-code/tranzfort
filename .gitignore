# TranZfort App - Git Ignore Configuration
# Excludes sensitive files, build artifacts, and documentation directories

# ============================================================================
# SENSITIVE FILES - NEVER COMMIT
# ============================================================================
# Environment files
.env
.env.local
.env.*.local
.env.development
.env.production
.env.staging

# Credentials and secrets
*.pem
*.key
*.p12
*.pfx
service-account*.json
credentials.json
google-services.json
GoogleService-Info.plist

# API keys and tokens
**/supabase_config.dart
**/maps_config.dart
**/firebase_config.dart

# ============================================================================
# DOCUMENTATION DIRECTORIES - EXCLUDED PER USER REQUEST
# ============================================================================
docs/
old-app/

# ============================================================================
# FLUTTER / DART BUILD ARTIFACTS
# ============================================================================
# Build outputs
build/
**/build/
.dart_tool/
.flutter-plugins
.flutter-plugins-dependencies
.packages
.pub-cache/
.pub/

# Generated files
*.g.dart
*.freezed.dart
*.mocks.dart

# ============================================================================
# PLATFORM-SPECIFIC BUILD DIRECTORIES
# ============================================================================
